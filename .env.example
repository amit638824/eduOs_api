NODE_ENV=development
PORT=3000

# PostgreSQL (use SSL in production)
DB_TYPE=postgres
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your_secure_password
DB_DATABASE=edutech
DB_SSL=true
DB_SSL_REJECT_UNAUTHORIZED=false
DB_POOL_MAX=20
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=5000

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=change_me_to_a_long_random_string_min_64_chars
JWT_REFRESH_SECRET=change_me_to_another_long_random_string_min_64_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS — comma-separated browser origins (no trailing slash)
# Production example:
# CORS_ORIGINS=https://onlineexam.techwagger.com,https://www.onlineexam.techwagger.com
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10

# Bcrypt
BCRYPT_ROUNDS=12

# App
APP_NAME=Super Computer Academy
TRUST_PROXY=1

# Frontend URLs (password reset / welcome / credentials emails)
# Local default when NODE_ENV=development:
FRONTEND_URL_LOCAL=http://localhost:5173
# Production default when NODE_ENV=production:
FRONTEND_URL_PROD=https://onlineexam.techwagger.com
# Override active link base (optional). If empty, picks LOCAL or PROD from NODE_ENV.
# For real emails from local API, set this to PROD so links are not localhost:
FRONTEND_URL=http://localhost:5173

# Email branding (absolute URLs — email clients cannot load localhost images)
EMAIL_ASSET_BASE=https://onlineexam.techwagger.com
LOGO_URL=https://onlineexam.techwagger.com/img/logo/sca-logo.png
EMAIL_CTA_DASHBOARD_PNG=https://onlineexam.techwagger.com/img/email/go-to-dashboard.png
EMAIL_CTA_RESET_PNG=https://onlineexam.techwagger.com/img/email/reset-password.png

# SMTP (Office365 / Gmail / etc.)
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=your_email@domain.com
SMTP_PASS=your_smtp_password
SMTP_FROM=your_email@domain.com
BCC_EMAILS=admin@domain.com

# Razorpay (test keys from dashboard.razorpay.com)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret
