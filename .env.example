NODE_ENV=development
PORT=3000

# PostgreSQL (use SSL in production)
DB_TYPE=postgres
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your_secure_password
DB_DATABASE=edutech
DB_SSL=true
DB_SSL_REJECT_UNAUTHORIZED=false
DB_POOL_MAX=20
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=5000

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=change_me_to_a_long_random_string_min_64_chars
JWT_REFRESH_SECRET=change_me_to_another_long_random_string_min_64_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS — comma-separated origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10

# Bcrypt
BCRYPT_ROUNDS=12

# App
APP_NAME=Super Computer Academy
TRUST_PROXY=1

# Frontend URL (password reset links, welcome emails)
FRONTEND_URL=http://localhost:5173

# SMTP (Office365 / Gmail / etc.)
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=your_email@domain.com
SMTP_PASS=your_smtp_password
SMTP_FROM=your_email@domain.com
BCC_EMAILS=admin@domain.com

# Razorpay (test keys from dashboard.razorpay.com)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret
